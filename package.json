{
  "name": "giotto",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "./src/app/globals.css"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); ['.next','.next-dev','.next-build','.next-dev-3002'].forEach((dir)=>fs.rmSync(dir,{recursive:true,force:true}));\"",
    "dev": "cross-env NEXT_DIST_DIR=.next-dev next dev -p 3000",
    "dev:fresh": "npm run clean && NEXT_DIST_DIR=.next-dev next dev -p 3000",
    "dev:network": "NEXT_DIST_DIR=.next-dev next dev -H 0.0.0.0 -p 3000",
    "dev:network:3002": "NEXT_DIST_DIR=.next-dev-3002 next dev -H 0.0.0.0 -p 3002",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "build": "npm run clean && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "clsx": "^2.1.1",
    "image-size": "^2.0.2",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "pg": "^8.16.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
