{
  "name": "giotto",
  "version": "0.1.0",
  "private": true,
  "sideEffects": ["**/*.css", "./src/app/globals.css"],
  "scripts": {
    "clean": "rm -rf .next .next-dev .next-build",
    "dev": "NEXT_DIST_DIR=.next-dev next dev -p 3000",
    "dev:fresh": "npm run clean && NEXT_DIST_DIR=.next-dev next dev -p 3000",
    "dev:network": "NEXT_DIST_DIR=.next-dev next dev -H 0.0.0.0 -p 3000",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
