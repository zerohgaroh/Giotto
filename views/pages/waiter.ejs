<!doctype html>
<html lang="ru">
  <head>
    <%- include("../partials/head", { pageTitle }) %>
  </head>
  <body>
    <script id="waiter-page-data" type="application/json"><%- serialize(waiterModel) %></script>

    <div x-data="waiterPage('waiter-page-data')">
      <main
        class="motion-page relative isolate mx-auto flex min-h-dvh max-w-guest flex-col overflow-hidden px-5 pb-8"
        style="padding-top:max(1.25rem,var(--safe-top));padding-bottom:max(1.5rem,var(--safe-bottom));"
      >
        <div class="pointer-events-none absolute inset-0 -z-10 opacity-45" aria-hidden="true">
          <svg viewBox="0 0 430 1400" preserveAspectRatio="none" class="h-full w-full">
            <g fill="none" stroke-linecap="round">
              <g stroke="rgba(10,31,74,0.12)" stroke-width="1.35">
                <path d="M-20 120 C 60 92, 140 148, 220 120 C 300 92, 380 148, 460 120"></path>
                <path d="M-20 300 C 60 272, 140 328, 220 300 C 300 272, 380 328, 460 300"></path>
                <path d="M-20 480 C 60 452, 140 508, 220 480 C 300 452, 380 508, 460 480"></path>
                <path d="M-20 660 C 60 632, 140 688, 220 660 C 300 632, 380 688, 460 660"></path>
                <path d="M-20 840 C 60 812, 140 868, 220 840 C 300 812, 380 868, 460 840"></path>
                <path d="M-20 1020 C 60 992, 140 1048, 220 1020 C 300 992, 380 1048, 460 1020"></path>
                <path d="M-20 1200 C 60 1172, 140 1228, 220 1200 C 300 1172, 380 1228, 460 1200"></path>
                <path d="M-20 1340 C 60 1312, 140 1368, 220 1340 C 300 1312, 380 1368, 460 1340"></path>
              </g>
              <g stroke="rgba(184,146,74,0.10)" stroke-width="1.1">
                <path d="M-20 210 C 60 182, 140 238, 220 210 C 300 182, 380 238, 460 210"></path>
                <path d="M-20 570 C 60 542, 140 598, 220 570 C 300 542, 380 598, 460 570"></path>
                <path d="M-20 930 C 60 902, 140 958, 220 930 C 300 902, 380 958, 460 930"></path>
                <path d="M-20 1290 C 60 1262, 140 1318, 220 1290 C 300 1262, 380 1318, 460 1290"></path>
              </g>
            </g>
          </svg>
        </div>

        <header class="text-center">
          <p class="font-sans text-[clamp(15px,4.2vw,17px)] font-bold tracking-tight text-giotto-navy-deep">Стол <%= tableLabel %></p>
          <p class="mt-1 font-sans text-[11px] font-semibold uppercase tracking-[0.22em] text-giotto-muted" x-text="requestType === 'bill' ? 'Запрос счёта' : 'Ожидайте официанта'"></p>
        </header>

        <section class="motion-surface relative mt-5 overflow-hidden rounded-[2.2rem] border border-white/70 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(255,255,255,0.86))] px-5 pb-12 pt-6 shadow-card backdrop-blur-md">
          <div class="absolute inset-x-0 top-0 h-28 bg-[radial-gradient(circle_at_top,rgba(184,146,74,0.14),transparent_72%)]"></div>
          <div class="text-center">
            <span class="inline-flex rounded-full border border-giotto-gold/35 bg-giotto-gold/10 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-giotto-navy-deep" x-text="requested ? (requestType === 'bill' ? 'Запрос счёта' : 'Вызов отправлен') : 'Сервис за столом'"></span>
            <h1 class="mt-2 font-serif text-[2.15rem] font-semibold leading-none text-giotto-navy-deep" x-text="requested ? (requestType === 'bill' ? 'Готовим счёт' : 'Официант вызван') : actionLabel"></h1>
            <p class="mx-auto mt-3 max-w-sm text-[14px] leading-relaxed text-giotto-muted" x-text="requested ? (requestType === 'bill' ? 'Повторный запрос счёта будет доступен через 2 минуты.' : 'Повторно позвать официанта можно только после окончания таймера.') : 'Нажмите кнопку ниже, чтобы отправить запрос именно по вашему столу.'"></p>
          </div>

          <div class="mx-auto mt-8 flex flex-col items-center">
            <div class="relative h-[min(68vmin,15rem)] w-[min(68vmin,15rem)] transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" :class="requested ? 'scale-100' : 'scale-[0.94]'">
              <svg width="256" height="256" viewBox="0 0 128 128" class="h-[min(68vmin,15rem)] w-[min(68vmin,15rem)] drop-shadow-[0_18px_36px_rgba(8,29,54,0.05)]" aria-hidden="true">
                <circle cx="64" cy="64" r="50" fill="none" stroke="#dde2ea" stroke-width="10"></circle>
                <circle
                  x-show="requested"
                  cx="64"
                  cy="64"
                  r="50"
                  fill="none"
                  stroke="#0a1f4a"
                  stroke-width="10"
                  stroke-linecap="round"
                  stroke-dasharray="314.1592653589793"
                  :stroke-dashoffset="dashOffset"
                  transform="rotate(-90 64 64)"
                  class="transition-[stroke-dashoffset] duration-700 ease-out"
                ></circle>
                <circle cx="64" cy="64" r="34" fill="white" stroke="#ebe6dc" stroke-width="1.5"></circle>
              </svg>

              <div class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center">
                <span class="flex h-[clamp(4.6rem,20vmin,5.35rem)] w-[clamp(4.6rem,20vmin,5.35rem)] items-center justify-center rounded-full bg-white text-giotto-navy-deep">
                  <svg viewBox="0 0 24 24" class="h-[clamp(2.3rem,10.5vmin,2.75rem)] w-[clamp(2.3rem,10.5vmin,2.75rem)]" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 17h5l-1.4-1.4a2 2 0 0 1-.6-1.4V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"></path>
                    <path d="M10 17a2 2 0 0 0 4 0"></path>
                  </svg>
                </span>
              </div>
            </div>

            <div class="mt-6 w-full overflow-hidden text-center transition-[height] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" :class="requested ? 'h-[6.1rem]' : 'h-[1.25rem]'">
              <div class="relative h-full">
                <div class="absolute inset-0 transition-all duration-350 ease-out" :class="requested ? 'translate-y-0 opacity-100' : 'translate-y-2 opacity-0 pointer-events-none'">
                  <p class="font-mono text-[clamp(2.9rem,14vw,3.5rem)] font-semibold tabular-nums tracking-[-0.04em] text-giotto-navy-deep" aria-live="polite" aria-atomic="true" x-text="formatCountdown(remaining)"></p>
                  <span class="mt-1 block font-sans text-[11px] font-semibold uppercase tracking-[0.22em] text-giotto-muted">до повторного вызова</span>
                </div>
                <div class="absolute inset-0 transition-all duration-350 ease-out" :class="requested ? '-translate-y-2 opacity-0 pointer-events-none' : 'translate-y-0 opacity-100'">
                  <span class="block font-sans text-[11px] font-semibold uppercase tracking-[0.22em] text-giotto-muted">Таймер начнётся после нажатия</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <div x-show="timerError" class="mt-3 rounded-lg border border-[#f2d7bf] bg-[#fff5ea] px-3 py-2 text-xs text-[#9a4f1e]" style="display:none" x-text="timerError"></div>

        <div class="mx-auto mt-auto flex w-full max-w-xs flex-col gap-3 pt-[clamp(2rem,8vh,3.5rem)]">
          <button
            type="button"
            class="motion-action min-h-[3.5rem] w-full rounded-[1.45rem] border-2 border-giotto-navy bg-giotto-navy font-sans text-[12px] font-bold uppercase tracking-[0.1em] text-white shadow-lift transition hover:bg-giotto-navy-deep disabled:cursor-not-allowed disabled:border-[#a7b2c8] disabled:bg-[#a7b2c8] disabled:text-white/80 disabled:shadow-none"
            :disabled="requested && !canRecall"
            @click="sendRequest()"
            x-text="actionLabel"
          ></button>
          <a href="<%= tablePath %>" class="motion-action flex min-h-[3.2rem] w-full items-center justify-center rounded-[1.35rem] border border-giotto-line bg-white/92 font-sans text-[14px] font-medium text-giotto-navy-deep backdrop-blur-sm transition hover:border-giotto-navy">На экран стола</a>
        </div>
      </main>

      <%- include("../partials/review-prompt", { tableId }) %>
    </div>
  </body>
</html>
