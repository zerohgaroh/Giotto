<!doctype html>
<html lang="ru">
  <head>
    <%- include("../partials/head", { pageTitle }) %>
  </head>
  <body>
    <script id="cart-page-data" type="application/json"><%- serialize(cartModel) %></script>

    <div x-data="cartPage('cart-page-data')">
      <main class="motion-page relative mx-auto flex min-h-dvh max-w-guest flex-col overflow-hidden bg-[#f6f1e8]">
        <header class="motion-surface relative z-20 border-b border-white/70 bg-white/70 backdrop-blur-xl" style="padding-top:max(0.5rem,var(--safe-top));">
          <div class="px-3 pb-3 pt-2">
            <div class="flex items-center gap-2">
              <a href="<%= menuPath %>" class="motion-action flex h-11 w-11 items-center justify-center rounded-full border border-[#d9cfbd] bg-white text-giotto-navy transition hover:bg-[#f8f3ea]" aria-label="К меню">←</a>
              <div class="min-w-0 flex-1 text-center">
                <h1 class="truncate font-serif text-[1.85rem] font-semibold leading-none text-giotto-navy-deep">Корзина</h1>
                <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-giotto-muted">заказ по столу</p>
              </div>
              <div class="h-11 w-11" aria-hidden="true"></div>
            </div>
          </div>
        </header>

        <main class="relative z-10 flex-1 overflow-y-auto px-3 pb-32 pt-3">
          <div x-show="resolvedLines.length === 0" class="px-2 py-14 text-center" style="display:none">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#eef2fb] text-giotto-navy">👜</div>
            <p class="mt-4 font-serif text-2xl font-semibold text-giotto-navy-deep">Пусто</p>
            <p class="mt-2 text-sm leading-relaxed text-giotto-muted">
              Добавьте блюда из меню, и корзина соберётся автоматически.
            </p>
            <a href="<%= menuPath %>" class="motion-action mt-5 inline-flex h-11 items-center justify-center rounded-[0.85rem] border border-[#d6ccba] bg-[#f7f2e8] px-6 text-sm font-semibold text-giotto-navy transition hover:bg-white">
              Перейти в меню
            </a>
          </div>

          <ul x-show="resolvedLines.length > 0" class="divide-y divide-[#e5dccb] border-y border-[#e5dccb] bg-transparent" style="display:none">
            <template x-for="line in resolvedLines" :key="line.dishId">
              <li class="bg-transparent">
                <div class="flex items-center gap-3 px-1 py-3">
                  <div class="relative h-[4.35rem] w-[5.4rem] shrink-0 overflow-hidden rounded-[0.8rem] bg-giotto-line">
                    <img :src="line.image" :alt="line.nameRu" loading="lazy" decoding="async" class="h-full w-full object-cover" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="line-clamp-2 font-sans text-[1rem] font-semibold leading-[1.2] text-giotto-ink" x-text="line.nameRu"></p>
                    <p class="mt-1 text-xs text-giotto-muted" x-text="`${formatPrice(line.price)} за порцию`"></p>
                    <p class="mt-1.5 font-sans text-[0.98rem] font-semibold text-giotto-navy-deep" x-text="formatPrice(line.price * line.qty)"></p>
                  </div>
                  <div class="inline-flex items-center rounded-full border border-[#d8cebc] bg-white/90 p-0.5">
                    <button type="button" class="motion-action flex h-8 w-8 items-center justify-center rounded-full text-giotto-navy transition hover:bg-[#f3eee4]" @click="setQty(line.dishId, line.qty - 1)" aria-label="Меньше">−</button>
                    <span class="min-w-[1.4rem] text-center text-[0.93rem] font-semibold text-giotto-navy-deep" x-text="line.qty"></span>
                    <button type="button" class="motion-action flex h-8 w-8 items-center justify-center rounded-full text-giotto-navy transition hover:bg-[#f3eee4]" @click="setQty(line.dishId, line.qty + 1)" aria-label="Больше">+</button>
                  </div>
                </div>
              </li>
            </template>
          </ul>

          <p x-show="errorMessage" class="mt-4 rounded-giotto border border-[#f2d7bf] bg-[#fff5ea] px-3 py-2 text-sm text-[#9a4f1e]" style="display:none" x-text="errorMessage"></p>
        </main>

        <div x-show="resolvedLines.length > 0" class="motion-surface fixed inset-x-0 bottom-0 z-40 border-t border-[#e2d8c7] bg-[#f8f3ea]/95 px-3 pb-[max(0.65rem,var(--safe-bottom))] pt-2 backdrop-blur-sm" style="display:none">
          <div class="mx-auto max-w-guest">
            <div class="mb-2 flex items-end justify-between px-0.5">
              <p class="text-[10px] uppercase tracking-[0.12em] text-giotto-muted">К оплате</p>
              <p class="text-xs text-giotto-muted" x-text="`${totalQty} шт.`"></p>
            </div>
            <div class="mb-2 px-0.5 font-serif text-[1.3rem] font-semibold leading-none text-giotto-navy-deep" x-text="formatPrice(totalSum)"></div>
            <button type="button" class="motion-action flex h-[50px] w-full items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-[#0d2a64] to-[#091c46] text-sm font-semibold text-white transition hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-60" :disabled="submitting" @click="checkout()">
              <span x-show="!submitting">Оформить заказ</span>
              <span x-show="submitting" style="display:none">Отправляем...</span>
            </button>
          </div>
        </div>
      </main>

      <%- include("../partials/review-prompt", { tableId }) %>
    </div>
  </body>
</html>
